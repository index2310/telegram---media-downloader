# Required
TELEGRAM_BOT_TOKEN=

# Optional (recommended)
MONGODB_URI=

# Optional admin diagnostics
# Comma-separated Telegram user IDs. If not set, /health is unavailable.
ADMIN_TELEGRAM_USER_IDS=

# Optional webhook configuration (polling is the default)
# If TELEGRAM_WEBHOOK_URL is set but PORT is not listening, the bot will fall back to polling.
TELEGRAM_WEBHOOK_URL=
PORT=

# Optional AI gateway (only used if some feature calls it)
COOKMYBOTS_AI_ENDPOINT=
COOKMYBOTS_AI_KEY=
AI_TIMEOUT_MS=600000
AI_MAX_RETRIES=2

# Optional tuning
RATE_LIMIT_X_PER_MIN=6
RATE_LIMIT_TIKTOK_PER_MIN=6
HTTP_TIMEOUT_MS=20000
HTTP_RETRIES=2
HTTP_MAX_REDIRECTS=5
MAX_MEDIA_BYTES=47185920

# Optional logs
HEARTBEAT_MS=60000

# Auto-synced env keys detected from process.env usage:
HTTP_USER_AGENT=
MEDIA_DOWNLOAD_ENDPOINT=
MEDIA_DOWNLOAD_KEY=

