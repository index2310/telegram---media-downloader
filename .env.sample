# Required
TELEGRAM_BOT_TOKEN=

# Optional (admin-only /health). Comma-separated numeric Telegram user IDs
ADMIN_TELEGRAM_USER_IDS=

# Optional database (disables DB features when missing)
MONGODB_URI=

# Optional webhook mode (ONLY enabled when PUBLIC_BASE_URL is set)
# Example: https://your-service.onrender.com
PUBLIC_BASE_URL=
# Optional: Telegram secret token header for webhook validation
TELEGRAM_WEBHOOK_SECRET=
# Optional: server port (Render sets this automatically)
PORT=3000

# Optional AI gateway (enabled only if both are set)
COOKMYBOTS_AI_ENDPOINT=
COOKMYBOTS_AI_KEY=
AI_TIMEOUT_MS=600000
AI_MAX_RETRIES=2

# Optional tuning
RATE_LIMIT_X_PER_MIN=6
RATE_LIMIT_TIKTOK_PER_MIN=6
HTTP_TIMEOUT_MS=20000
HTTP_RETRIES=2
HTTP_MAX_REDIRECTS=5
MAX_MEDIA_BYTES=47185920
HTTP_USER_AGENT=

# Optional TikTok RapidAPI fallback (feature is disabled when missing)
RAPIDAPI_KEY=

# Diagnostics
HEARTBEAT_MS=60000
